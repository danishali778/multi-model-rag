# Production app contract for API and worker containers.

APP_NAME=multi-model-rag
ENVIRONMENT=production
LOG_LEVEL=INFO
ALLOW_DEV_API_KEY=false
API_KEY=<disable-or-use-only-for-internal-bootstrap>
INTERNAL_SERVICE_TOKEN=<internal-service-token>
RUNTIME_ROLE=api
TELEMETRY_SERVICE_NAME=multi-model-rag-api

SUPABASE_DB_URL=<managed-postgres-url>
SUPABASE_JWKS_URL=https://<project-ref>.supabase.co/auth/v1/.well-known/jwks.json
SUPABASE_JWT_ALGORITHM=ES256
SUPABASE_JWT_AUDIENCE=authenticated
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=<supabase-anon-key>
SUPABASE_SERVICE_ROLE_KEY=<supabase-service-role-key>
SUPABASE_RAW_DOCUMENTS_BUCKET=raw-documents
SUPABASE_PROCESSED_DOCUMENTS_BUCKET=processed-documents
SUPABASE_VOICE_BUCKET=voice-artifacts

REDIS_URL=redis://<managed-redis-host>:6379/0
CELERY_TASK_ALWAYS_EAGER=false
CELERY_BROKER_URL=redis://<managed-redis-host>:6379/0
CELERY_RESULT_BACKEND=redis://<managed-redis-host>:6379/0

GROQ_API_KEY=<groq-api-key>
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL_FAST=llama-3.1-8b-instant
GROQ_MODEL_BALANCED=llama-3.3-70b-versatile
GROQ_MODEL_REASONING=deepseek-r1-distill-llama-70b

OPENAI_API_KEY=<openai-api-key>
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL_FAST=gpt-4o-mini
OPENAI_MODEL_BALANCED=gpt-4.1-mini
OPENAI_MODEL_EMBEDDING=text-embedding-3-small

ANTHROPIC_API_KEY=<anthropic-api-key>
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1
ANTHROPIC_MODEL_FAST=claude-3-5-haiku-latest
ANTHROPIC_MODEL_BALANCED=claude-3-5-sonnet-latest
ANTHROPIC_MODEL_REASONING=claude-3-7-sonnet-latest

OLLAMA_BASE_URL=http://ollama.internal:11434
OLLAMA_MODEL_LOCAL=llama3.1:8b

HF_API_TOKEN=<huggingface-api-token>
HF_BASE_URL=https://api-inference.huggingface.co/models
HF_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

CHAT_PROFILE_FAST_CHAIN=
CHAT_PROFILE_BALANCED_CHAIN=
CHAT_PROFILE_REASONING_CHAIN=
CHAT_PROFILE_LOCAL_CHAIN=
EMBEDDING_PROFILE_CHAIN=

CHUNK_SIZE=900
CHUNK_OVERLAP=120
MAX_CONTEXT_CHUNKS=8
MAX_OUTPUT_TOKENS=512
CHUNKING_VERSION=recursive-v1
PROMPT_VERSION=grounded-v1
EMBEDDING_DIMENSION=384

TRACING_ENABLED=true
TRACING_EXPORTER_OTLP_ENDPOINT=http://otel-collector.monitoring.svc.cluster.local:4317
CORS_ALLOWED_ORIGINS=https://app.example.com
